// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// ──────────────────────────────────────────
// USER
// ──────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  bio       String?
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  missions        Mission[]     @relation("FounderMissions")
  missionSwipes   MissionSwipe[]
  profileSwipes   ProfileSwipe[] @relation("FounderSwipes")
  receivedSwipes  ProfileSwipe[] @relation("DeveloperSwipes")
  developerMatches Match[]      @relation("DeveloperMatches")
  founderMatches   Match[]      @relation("FounderMatches")
}

enum UserRole {
  FOUNDER
  DEVELOPER
}

// ──────────────────────────────────────────
// MISSION
// ──────────────────────────────────────────

model Mission {
  id          String        @id @default(uuid())
  title       String
  description String
  status      MissionStatus @default(OPEN)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  founderId     String
  founder       User           @relation("FounderMissions", fields: [founderId], references: [id])
  swipes        MissionSwipe[]
  matches       Match[]
}

enum MissionStatus {
  OPEN
  CLOSED
}

// ──────────────────────────────────────────
// MISSION SWIPE (DEVELOPER swipe a mission)
// ──────────────────────────────────────────

model MissionSwipe {
  id        String         @id @default(uuid())
  direction SwipeDirection
  status    SwipeStatus?
  createdAt DateTime       @default(now())

  // Relations
  developerId String
  missionId   String
  developer   User    @relation(fields: [developerId], references: [id])
  mission     Mission @relation(fields: [missionId], references: [id])

  @@unique([developerId, missionId])
}

// ──────────────────────────────────────────
// PROFILE SWIPE (FOUNDER swipe a developer)
// ──────────────────────────────────────────

model ProfileSwipe {
  id        String         @id @default(uuid())
  direction SwipeDirection
  status    SwipeStatus?
  createdAt DateTime       @default(now())

  // Relations
  founderId   String
  developerId String
  founder     User @relation("FounderSwipes", fields: [founderId], references: [id])
  developer   User @relation("DeveloperSwipes", fields: [developerId], references: [id])

  @@unique([founderId, developerId])
}

enum SwipeDirection {
  LIKE
  DISLIKE
}

enum SwipeStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ──────────────────────────────────────────
// MATCH
// ──────────────────────────────────────────

model Match {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Relations
  developerId String
  founderId   String
  missionId   String
  developer   User    @relation("DeveloperMatches", fields: [developerId], references: [id])
  founder     User    @relation("FounderMatches", fields: [founderId], references: [id])
  mission     Mission @relation(fields: [missionId], references: [id])

  @@unique([developerId, missionId])
}